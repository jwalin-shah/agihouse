# Copy this to .env.local only if you need to override auto-detection.
#
# By default the app connects to:
#   ws://<same-host-that-served-the-app>:9849/g2/ws
#
# Use ngrok for stability across WiFi changes:
#   ngrok http 9849
# Then set this to the ngrok wss:// URL
# VITE_INBOX_WS_URL=wss://<your-id>.ngrok.app/g2/ws
