{
  "package_id": "com.evenhub.ambientcopilot",
  "edition": "202601",
  "name": "Ambient Copilot",
  "version": "0.1.0",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Connects to local agent server for HUD commands",
      "whitelist": ["ws://localhost:9849", "ws://127.0.0.1:9849"]
    },
    {
      "name": "g2-microphone",
      "desc": "Ambient audio capture for context awareness"
    },
    {
      "name": "location",
      "desc": "Location-based context triggers"
    }
  ],
  "supported_languages": ["en"]
}
