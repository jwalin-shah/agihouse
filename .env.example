# Presence environment
# Copy this file to .env and fill the blank values.
# Never commit .env.

# Required: OpenAI
# Create at https://platform.openai.com/api-keys
# Leave OPENAI_API_KEY blank if using OpenRouter for text and browser speech recognition for STT.
OPENAI_API_KEY=

# Optional: OpenRouter for text/chat models.
# Create at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://<MAC_LAN_IP>:5173
OPENROUTER_APP_NAME=Presence G2

# User-selected text model for classification, summaries, memory retrieval, and HUD answers.
# For OpenRouter, use provider-prefixed IDs such as openai/gpt-5.4-nano.
OPENAI_TEXT_MODEL=openai/gpt-5.4-nano

# Audio transcription model through OpenRouter. Used for G2 mic PCM -> text.
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash-lite

# Speech-to-text model.
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optional: set only if using a proxy or compatible provider.
OPENAI_BASE_URL=


# Required: local backend
# The backend should bind to 0.0.0.0 so the phone can reach it over Wi-Fi.
PRESENCE_BACKEND_HOST=0.0.0.0
PRESENCE_BACKEND_PORT=8787

# Required for phone/G2 testing.
# Replace <MAC_LAN_IP> with your Mac's Wi-Fi IP address, e.g. http://192.168.1.42:8787
# Find it on macOS with: ipconfig getifaddr en0
PUBLIC_BACKEND_URL=http://<MAC_LAN_IP>:8787

# Vite exposes only VITE_* variables to the browser app.
# Use the same value as PUBLIC_BACKEND_URL.
VITE_PRESENCE_BACKEND_URL=http://<MAC_LAN_IP>:8787

# G2 mic sends roughly this many seconds of PCM per transcription request.
VITE_G2_AUDIO_CHUNK_SECONDS=60

# Legacy voice-command window, currently unused because touch/Ask mode owns commands.
VITE_G2_COMMAND_CHUNK_SECONDS=8

# Ask mode listens in short windows for proactive smart-glasses suggestions.
VITE_G2_ASK_CHUNK_SECONDS=5


# Required: Obsidian markdown memory store
# Use an absolute path. This can be any folder that you later open as an Obsidian vault.
OBSIDIAN_VAULT_PATH=/Users/charvikusuma/Documents/Tarun/er_hack/vault
OBSIDIAN_VAULT_NAME=Presence

# Local timezone for daily/hourly memory files.
MEMORY_TIMEZONE=America/Los_Angeles


# Required: owner/profile
OWNER_NAME=Steve

# MVP can keep this false and use tap/push-to-talk as owner confirmation.
# Set true later if we add real speaker verification.
OWNER_VOICE_LOCK_ENABLED=false
OWNER_VOICE_SAMPLE_PATH=


# Memory pipeline tuning
# 300 seconds = 5-minute summary windows.
CAPTURE_WINDOW_SECONDS=300

# 60 minutes = hourly memory rollup.
HOURLY_ROLLUP_MINUTES=60

# Keep HUD answers short for G2.
HUD_MAX_LINES=4
HUD_MAX_CHARS_PER_LINE=32

# Prevent repeated proactive nudges for the same cue.
PROACTIVE_COOLDOWN_MS=4500


# Audio/VAD tuning
VAD_ENABLED=true
VAD_MIN_SPEECH_MS=500
VAD_SILENCE_MS=1200

# Leave blank for auto-detect. Use "en" if we force English input.
STT_LANGUAGE=

# Target language for saved summaries and answers.
MEMORY_OUTPUT_LANGUAGE=en


# Demo/debug
DEMO_MODE=true
LOG_LEVEL=debug


# Optional later: coarse location enrichment
# Only needed if we add reverse geocoding.
GOOGLE_MAPS_API_KEY=
